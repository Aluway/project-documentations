{
  "name": "project-documentations",
  "version": "0.1.0",
  "description": "Documentation standards template for AI-agent-assisted frontend projects — Feature-Sliced Design 2.1, React + TypeScript, git workflow, security, ADRs, and a zero-dependency documentation linter.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Artem Buzov (https://github.com/Aluway)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aluway/project-documentations.git"
  },
  "bugs": {
    "url": "https://github.com/Aluway/project-documentations/issues"
  },
  "homepage": "https://github.com/Aluway/project-documentations#readme",
  "keywords": [
    "documentation",
    "template",
    "ai-agents",
    "agents-md",
    "feature-sliced-design",
    "fsd",
    "react",
    "typescript",
    "adr",
    "architecture-decision-records",
    "frontend",
    "code-style",
    "governance"
  ],
  "files": [
    "AGENTS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    ".env.example",
    "docs/",
    "scripts/",
    ".github/"
  ],
  "bin": {
    "project-documentations": "./scripts/install.mjs"
  },
  "scripts": {
    "lint": "node scripts/lint-docs.mjs",
    "lint:docs": "node scripts/lint-docs.mjs",
    "install:template": "node scripts/install.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
