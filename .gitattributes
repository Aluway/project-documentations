# Enforce LF line endings for all text files across platforms.
# Forks on Windows / macOS / Linux end up with identical bytes in git,
# avoiding noisy CRLF↔LF diffs between contributors.

* text=auto eol=lf

# Explicit for common text formats in this template.
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.mjs        text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.sh         text eol=lf
*.example    text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
LICENSE      text eol=lf

# Binary — do not touch.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
